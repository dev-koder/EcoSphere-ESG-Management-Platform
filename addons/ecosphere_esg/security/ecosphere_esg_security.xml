<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="module_category_esg" model="ir.module.category">
            <field name="name">ESG Management</field>
            <field name="description">Helps you manage ESG and gamification.</field>
            <field name="sequence">10</field>
        </record>

        <record id="group_esg_user" model="res.groups">
            <field name="name">User</field>
            <field name="category_id" ref="module_category_esg"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_esg_manager" model="res.groups">
            <field name="name">Department Head</field>
            <field name="category_id" ref="module_category_esg"/>
            <field name="implied_ids" eval="[(4, ref('group_esg_user'))]"/>
        </record>

        <record id="group_esg_admin" model="res.groups">
            <field name="name">Administrator</field>
            <field name="category_id" ref="module_category_esg"/>
            <field name="implied_ids" eval="[(4, ref('group_esg_manager'))]"/>
        </record>
    </data>
</odoo>
