<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Environmental Goal Views -->
    <record id="view_esg_environmental_goal_tree" model="ir.ui.view">
        <field name="name">esg.environmental.goal.tree</field>
        <field name="model">esg.environmental.goal</field>
        <field name="arch" type="xml">
            <tree string="Environmental Goals" decoration-success="status == 'achieved'" decoration-warning="status == 'at_risk'" decoration-danger="status == 'missed'" decoration-info="status == 'on_track'">
                <field name="name"/>
                <field name="department_id"/>
                <field name="metric"/>
                <field name="current_value"/>
                <field name="target_value"/>
                <field name="deadline"/>
                <field name="status" widget="badge" decoration-success="status == 'achieved'" decoration-warning="status == 'at_risk'" decoration-danger="status == 'missed'" decoration-info="status == 'on_track'"/>
            </tree>
        </field>
    </record>

    <record id="view_esg_environmental_goal_form" model="ir.ui.view">
        <field name="name">esg.environmental.goal.form</field>
        <field name="model">esg.environmental.goal</field>
        <field name="arch" type="xml">
            <form string="Environmental Goal">
                <header>
                    <field name="status" widget="statusbar" statusbar_visible="on_track,at_risk,achieved,missed"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="department_id"/>
                            <field name="metric"/>
                        </group>
                        <group>
                            <field name="start_date"/>
                            <field name="deadline"/>
                        </group>
                    </group>
                    <group string="Values">
                        <group>
                            <field name="baseline_value"/>
                            <field name="target_value"/>
                        </group>
                        <group>
                            <field name="current_value"/>
                            <field name="uom"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_esg_environmental_goal" model="ir.actions.act_window">
        <field name="name">Sustainability Goals</field>
        <field name="res_model">esg.environmental.goal</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
