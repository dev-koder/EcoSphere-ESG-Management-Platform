<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
    <t t-name="ecosphere_esg.LeaderboardWidget" owl="1">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <i class="fa fa-trophy me-2"/> Top 10 Leaderboard
            </div>
            <div class="card-body p-0">
                <table class="table table-striped table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Rank</th>
                            <th>Employee</th>
                            <th>Department</th>
                            <th class="text-end">XP</th>
                            <th class="text-end">Points</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr t-foreach="props.leaderboard" t-as="emp" t-key="emp_index">
                            <td>#<t t-esc="emp_index + 1"/></td>
                            <td class="fw-bold"><t t-esc="emp.name"/></td>
                            <td><t t-esc="emp.department"/></td>
                            <td class="text-end text-success fw-bold"><t t-esc="emp.xp"/></td>
                            <td class="text-end text-primary"><t t-esc="emp.points"/></td>
                        </tr>
                        <tr t-if="!props.leaderboard.length">
                            <td colspan="5" class="text-center py-4 text-muted">
                                No leaderboard data available.
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </t>
</templates>
